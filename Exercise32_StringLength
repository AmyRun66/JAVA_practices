import java.util.Scanner;

public class Main{
    
    public static void main(String[] args){
        
        //Mostrar la longitud de una cadena.
        
        System.out.println("Introduce una palabra: ");
        
        Scanner teclado = new Scanner(System.in);
        
        String textuser = teclado.nextLine();
        
        int contador = 1;
        
        for (int i = textuser.length(); i > 1; i--){
            
            contador++;
            
        }
        
        if (contador == 1){
            
            System.out.println("La palabra consta de " + contador + " carácter.");
            
        } else {
            
            System.out.println("La palabra consta de " + contador + " carácteres.");
            
        }
        
    }
    
}
