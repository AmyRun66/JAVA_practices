import java.util.Scanner;

public class Main {
    
    public static void main(String[] args) {
        
        //Crea una aplicación que nos pida un día de la semana y que nos diga si es un dia laboral o no. Usa un switch para ello.
        
        System.out.println("Vamos a comprobar si el día es laborable o festivo. Introduce un día de la semana: ");
        
        Scanner teclado = new Scanner(System.in);
        
        String day = teclado.nextLine();
        
        switch(day) {
            
            case "lunes":
            case "martes":
            case "miércoles":
            case "jueves":
            case "viernes":
            
                System.out.println("Es laborable.");
                break;
            
            case "sábado":
            case "domingo":
            
                System.out.println("Es festivo");
                break;
                
            default:
                
                System.out.println("No es un día de la semana, o, no lo has escrito en minúsculas y de forma correcta.");
                        
        }
        
    }
}
