public class Main {
    
    public static void main(String[] args){
        
        //Imprime los números del 1 al 100 divisibles entre 3.
        
        for (int i = 1; i <= 100; i++) {
            
            int resto = i % 3;
            
            if (resto == 0) {
                
                System.out.println(i);
                
            }
            
        }
        
    }
    
    
}
