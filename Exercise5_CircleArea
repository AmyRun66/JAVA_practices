import java.util.Scanner;

public class Main {
    
    public static void main(String[] args){
        
        //Haz una aplicación que calcule el área de un círculo(pi*R2). El radio se pedirá por teclado.
        
        Scanner numerousuario = new Scanner(System.in);
        
        System.out.println("Introduce el radio de la circunferencia: ");
              
        double radio=numerousuario.nextDouble();
        
        double area=Math.PI*Math.pow(radio, 2);
        
        System.out.println("El area del círculo es " + area);     
                
    }
}
