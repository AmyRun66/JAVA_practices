import java.util.Scanner;

public class Main{
    
    public static void main(String[] args){
        
    //Realizar la suma del intervalo entre 1 y el numero que indiquemos.
        
    Scanner teclado = new Scanner(System.in);
    
    int num1 = 1;
    
    System.out.println("Introduce un número mayor que 1: ");
    
    int num = teclado.nextInt();
    
    int resultado = 0;
    
    if(num <= 1){
        
        System.out.println("Error. No has introducido un número mayor que 1");
        
    } else {
        
        for (int i = 0; num >= i; ++i){
            
            resultado = resultado + i;
            
        }
        
        System.out.println("La suma de los números es: " + resultado);
        
    }  
       
    }
    
}
