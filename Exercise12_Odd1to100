public class Main {
    
    public static void main(String[] args) {
        
        //Muestra los números impares del 1 al 100.
        
        for (int i = 1; i <= 100; i++) {
            
            int resto = i % 2;
            
            if (resto != 0) {
                
                System.out.println(i);
            }
        }
        
    }
}
