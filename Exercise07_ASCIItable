import java.util.Scanner;

public class Main {
    
    public static void main(String[] args){
        
        //Lee un número por teclado y muestra por consola, el carácter al que pertenece en la tabla ASCII.
        
        Scanner teclado = new Scanner(System.in);
        
        System.out.println("Introduce un número del 1 al 255: ");
        
        int num = teclado.nextInt();
        
        if (num >= 1 && num <=255){
            
            char caracter = (char) num; //Realizamos un casting para cambiar el tipo a char y que emita el UNICODE; los 256 caracteres coinciden conlos de ASCII.
            
            System.out.println("El número " + num + " equivale en la tabla ASCII a " + caracter);
        } else {
            
            System.out.println("El rango permitido es desde el 1 al 255.");
        }
        
    }
}
