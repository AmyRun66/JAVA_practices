import java.util.Scanner;

public class Main {
    
    public static void main(String[] args){
        
        //Pide un número por teclado e indica si es un número primo o no.
        
        Scanner teclado = new Scanner(System.in);
        
        int num = teclado.nextInt();
        
        int contador = 0; //Número de divisibles (por cuántos números se puede dividir.
              
        if (num <= 1){
            
            System.out.println("El número, no es primo.");         
            
        } else {
            
            int raiz = (int)Math.sqrt(num); //Poniendo int entre paréntesis, obligamos a que la raíz cuadrada dé un resultado de número entero; sin decimales.
            
            for(int i = raiz; i > 1; i--){ //Va a repetir la acción con un contador cuenta atrás hasta 1.
                
                if(num % i == 0){ //Se va asegurar de que el resto de la división entre num y el nº de la cuenta atrás sea 0.
                    
                    contador++;
                    
                }
                
            }
            
        }
        
        if (contador < 1){
            
            System.out.println("El número " + num + " no tiene divisibles y por tanto, es primo.");
            
        } else if (contador == 1){
            
            System.out.println("El número " + num + " tiene un divisible y por tanto, no es primo.");
            
        } else {
            
            System.out.println("El número " + num + " tiene " + contador + " divisibles y por tanto, no es primo.");
            
        }
        
    }
}
